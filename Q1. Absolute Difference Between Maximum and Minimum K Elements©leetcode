class Solution {
public:
    int absDifference(vector<int>& nums, int k) {
        int n = nums.size();
        if(n==1) return 0;
          sort(nums.begin(),nums.end());
       
        int sum1 =0, sum2 = 0;
        
        for(int i=0; i<k; i++){
            sum1 += nums[i];
        }
        int c = 0;
        for(int i=n-1; i>=0; i--){
            if(c != k){
                sum2 += nums[i];
                c++;
            }else {
                break;
            }

        }
        return sum2-sum1;
    }
};©leetcode
