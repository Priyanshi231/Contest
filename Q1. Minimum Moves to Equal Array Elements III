class Solution {
public:
    int minMoves(vector<int>& nums) {
        int n =nums.size();
        int m = 0;
        int c = 0;
        for(int i=0; i<n; i++){
            m = max(nums[i], m);
        }
        for(int i=0; i<n; i++){
            while(nums[i] != m){
                nums[i]++;
                c++;
            }
        }
        return c;
    }
};©leetcode
