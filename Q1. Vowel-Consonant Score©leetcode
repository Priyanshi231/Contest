class Solution {
public:
    int vowelConsonantScore(string s) {
        int n = s.size();
        int cv = 0;
        int cc = 0;
   
        
        for(int i=0; i<n; i++){
            if (!isalpha(s[i])) continue;  
            s[i] = tolower(s[i]);
            
            if(s[i] == 'a' || s[i] == 'e' || s[i] == 'i' || s[i] == 'o' || s[i] == 'u' ){
                cv++;
            }
            else{
                cc++;
            }
        }
       
        if(cc == 0 || cv == 0){
            return 0;
        }
    
        return floor(cv/cc);
    }
};©leetcode
