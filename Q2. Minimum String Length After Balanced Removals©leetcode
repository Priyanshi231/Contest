class Solution {
public:
    int minLengthAfterRemovals(string s) {
        int n = s.length();
        int ca = 0, cb = 0;
 
        for(int i=0; i<n; i++){
            if(s[i] == 'a'){
                ca ++;
            }
            else if(s[i] == 'b'){
                cb++;
            }
        }
        int ans = ca - cb;
        return abs(ans);
    }
};©leetcode
