class Solution {
public:
    long long removeZeros(long long n) {
        long long ans =0;
        long long p = 1;
        while(n>0){
            int dig = n%10;
            if (dig != 0){
                ans += dig * p;
                p *= 10;
            }
            n = n/10;
        }
        return ans;
    }
};©leetcode
